{{assign 'button_instances' (@root.SWConfigurationAPI.getInstances  "STMicroelectronics::Board Part:STM32CubeMX2 Config:Button")~}}
{{assign 'IsgpioUsed' false~}}
{{#each @root.button_instances~}}
{{assign 'ctx' (@root.SWConfigurationAPI.getSwInstanceConfiguration this)~}}
{{#if (eq @root.ctx.info.interface 'GPIO')~}}
{{assign 'IsgpioUsed' true~}}
{{/if}}
{{/each}}
<?xml version="1.0" encoding="UTF-8"?>
<!-- ***************************************************************************
 * File Name   : {{@root.pdscAPI.getGPDSCFileName}}
 * Description : Generator PDSC File generated by the code generator
  ******************************************************************************
  * @attention
  *
  * Copyright (c) {{#unless (eq 2026 (toInt (year)))}}2026-{{/unless}}{{year}} STMicroelectronics.
  * All rights reserved.
  *
  * This software is licensed under terms that can be found in the mx_button_part_drivers_license.md file
  * in the same directory as the generated code.
  * If no mx_button_part_drivers_license.md file comes with this software, it is provided AS-IS.
  *
 ****************************************************************************** -->
<package xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.7.55" xsi:noNamespaceSchemaLocation="PACK.xsd" xmlns:stm32="https://developer.st.com/schemas/stm32cube/1.0.0" xsi:schemaLocation="https://developer.st.com/schemas/stm32cube/1.0.0 stm32cube.xsd">
  {{!--Dedicated Helper that provides the PDSC PackVendor--}}
  <vendor>{{@root.pdscAPI.getPackVendor}}</vendor>
  {{!--Dedicated Helper that provides the PDSC PackName--}}
  <name>{{@root.pdscAPI.getPackName}}</name>
  {{!--URL Tag, kept here since its required for valid schema parsing--}}
  <url>{{@root.pdscAPI.getPackURL}}</url>
  {{!--Release Section to update manually in case of new updated--}}
  <releases>
    <release version="0.0.1" date="2024-07-17">
      - First GPDSC template Model Release
    </release>
  </releases>
  <conditions>
    {{!-- this is a dedicated Helper to extract All PDSC conditions and inject them into the <conditions></conditions>
    section--}}
    {{!-- This Helper supports condition exclusions using the following synthaxe--}}
    {{!-- {{assign "conditions" (@root.pdscAPI.getAllPDSCConditionsWithFilters exclude="CMSIS OS, TEMPLATE OS, Timebase
    Init")}} --}}
    {{!-- the following 2 lines are mandatory to keep for PDSC conditions inclusion at GPDSC generation in runtime--}}
    {{assign "conditions" (@root.pdscAPI.getAllPDSCConditionsWithFilters  exclude="Button CFG Condition")}}
    {{{@root.conditions}}}
    {{!-- Excluded conditions by Id above could optionally be handled dynamically in this section--}}
    {{!-- #Start Dynamic condition handling section# --}}
    <condition id="Button CFG Condition">
      <description>STMicroelectronics configuration for Button part driver</description>
{{#if (eq IsgpioUsed true)}}
        <require Cclass="Board Part" Cgroup="Button" Csub="gpio"/>
{{/if}}
    </condition>
    {{!-- #End Dynamic condition handling section# --}}

  </conditions>
  {{!-- This section will list all selected components with their descriptions, along with their generated files--}}
  {{!-- This is supported by codegen version >= v6.13.0 --}}
  <components>
    {{#each components}}
    <component {{{generatorId}}} {{{Cclass}}} {{{Cgroup}}} {{{Csub}}} {{{Cvariant}}} {{{Cversion}}} {{{condition}}}>
      <description>{{description}}</description>
      <files>
        {{#each files_array}}
        <file category="{{category}}" name="{{gen_file}}" />
        {{/each}}
      </files>
    </component>
    {{/each}}
  </components>
</package>
