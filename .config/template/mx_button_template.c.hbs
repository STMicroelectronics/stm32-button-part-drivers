{{assign 'button_instances' (@root.SWConfigurationAPI.getInstances  "STMicroelectronics::Board Part:STM32CubeMX2 Config:Button")~}}

/* Includes ---------------------------------------------------------------- */
#include "mx_button.h"

{{!---------------------- Part OBJs ----------------------------------------------------------}}
{{#each @root.button_instances}}
{{assign 'ctx' (@root.SWConfigurationAPI.getSwInstanceConfiguration this)~}}
static button_t  button_{{@index}}_obj;
{{/each}}

{{!---------------------- Part WEAK FUNC -----------------------------------------------------}}
/**
  * @brief initialize the IO layer.
  * @param  pio      pointer to the part IO structure.
  * @retval error status.
  */
int32_t button_io_init(button_t *pio)
{
  /* Part Status */
  int32_t ret = 0;

  switch (pio->id)
  {
{{#each @root.button_instances}}
{{assign 'ctx' (@root.SWConfigurationAPI.getSwInstanceConfiguration this)~}}
{{#with @root.ctx}}
    case BUTTON_{{@index}}:
{{#if (eq info.interface 'GPIO')}}
      pio->port      = BUTTON_{{@index}}_GPIO_PORT;
      pio->pin       = BUTTON_{{@index}}_GPIO_PIN;
      pio->active_state = BUTTON_{{@index}}_GPIO_ACTIVE_STATE;
      pio->exti_handle = BUTTON_{{@index}}_EXTI_GETHANDLE();
#if defined (BUTTON_DEBOUNCE) && (BUTTON_DEBOUNCE == 1)
{{#if (eq resourcesAllocation.gpioCfg.debounceIsEnabled true)}}
      pio->debounce_duration       = BUTTON_{{@index}}_DEBOUNCE_DURATION;
{{else}}
      pio->debounce_duration       = 0u;
{{/if}}
      pio->last_event_tick       = 0u;
      if (HAL_GPIO_ReadPin(pio->port, pio->pin) == HAL_GPIO_PIN_SET)
      {
        pio->last_event = HAL_EXTI_TRIGGER_RISING;
      }
      else
      {
        pio->last_event = HAL_EXTI_TRIGGER_FALLING;
      }
#endif /* BUTTON_DEBOUNCE */
{{/if}}
      break;

{{/with}} {{!-- @root.ctx --}}
{{/each}} {{!-- @root.button_instances --}}
    default:
      /* Error -- Unknown ID */
      ret = -1;
      break;
  }

  return ret;
}

{{!---------------------- Part Getters FUNC --------------------------------------------------}}
{{#each @root.button_instances}}
{{assign 'ctx' (@root.SWConfigurationAPI.getSwInstanceConfiguration this)~}}
{{#with @root.ctx}}
/**
  * @brief Function to retrieve the Part object Button_{{@index}}.
  * @retval part object.
  */
button_t *mx_button_{{@index}}_getobject(void)
{
  return &button_{{@index}}_obj;
}
{{/with}} {{!-- @root.ctx --}}
{{/each}} {{!-- @root.button_instances --}}
