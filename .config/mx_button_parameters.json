{
  "componentid": "::Board Part:STM32CubeMX2 Config:Button",
  "type": "object",
  "grammarVersion": "3.7.0",
  "license": "Copyright (c) 2026 STMicroelectronics",
  "properties": {
    "parameters": {
      "type": "object",
      "properties": {
        "info": {
          "title": "Button configuration",
          "type": "object",
          "properties": {
            "labels": {
              "type": "array",
              "title": "SW Label for parts objects",
              "description": "Labels allow to create aliases inside mx_button.h file for the object ID and object getter function. These aliases can be used on application side.",
              "items": {
                "type": "string",
                "minLength": 0,
                "maxLength": 32,
                "unique": "project",
                "default": "",
                "actions": [
                  {
                    "type": "error",
                    "condition": "!/^[A-Za-z_][A-Za-z0-9_]*$/.test($value)",
                    "message": "Name must be a valid C identifier: start with a letter or underscore, and contain only letters, digits, or underscores."
                  }
                ]
              }
            },
            "interface": {
              "title": "Interface selection",
              "description": "Select the Interface to be configured",
              "type": "string",
              "oneOf": [
                {
                  "const": "GPIO",
                  "title": "GPIO"
                }
              ],
              "default": "GPIO"
            }
          }
        },
        "resourcesAllocation": {
          "type": "object",
          "properties": {
            "gpioCfg": {
              "type": "object",
              "title": "GPIO Interface Configuration",
              "description": "Button GPIO Interface configuration",
              "actions": [
                {
                  "type": "include",
                  "condition": "$info.interface === 'GPIO'"
                }
              ],
              "properties": {
                "gpioCfg": {
                  "title": "Pin selection",
                  "type": "object",
                  "objectType": "bind.gpio.config",
                  "description": "The GPIO pin must be configured as an input in HAL GPIO configuration panel",
                  "pins": {
                    "gpioPin": {
                      "title": "GPIO PIN",
                      "constraints": {
                        "mode": {
                          "const": "INPUT"
                        }
                      }
                    }
                  },
                  "actions": [
                    {
                      "type": "error",
                      "condition": "!$resourcesAllocation.gpioCfg.gpioCfg?.selection",
                      "message": "Please select a GPIO pin configured as input in HAL GPIO configuration panel."
                    }
                  ]
                },
                "polarity": {
                  "type": "string",
                  "title": "Logical level when pressed",
                  "oneOf": [
                    {
                      "const": "HAL_GPIO_PIN_SET",
                      "title": "HIGH"
                    },
                    {
                      "const": "HAL_GPIO_PIN_RESET",
                      "title": "LOW"
                    }
                  ],
                  "default": "HAL_GPIO_PIN_SET"
                },
                "debounceIsEnabled": {
                  "title": "Use software debounce",
                  "type": "boolean"
                },
                "debounceValue": {
                  "title": "Debounce timeout (ms)",
                  "type": "integer",
                  "actions": [
                    {
                      "type": "include",
                      "condition": "$resourcesAllocation.gpioCfg.debounceIsEnabled"
                    }
                  ],
                  "minimum": 0,
                  "maximum": 100,
                  "default": 10,
                  "unit": "ms",
                  "display_format": [
                    "dec"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
